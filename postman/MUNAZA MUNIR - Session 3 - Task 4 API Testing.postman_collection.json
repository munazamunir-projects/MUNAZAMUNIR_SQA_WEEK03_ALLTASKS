  "item": [
    {
      "name": "GET - All Posts",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Check Status Code\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// Check Response Time\r",
              "pm.test(\"Response time is less than 1000ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(1000);\r",
              "});\r",
              "\r",
              "// Check Response is JSON\r",
              "pm.test(\"Response is JSON\", function () {\r",
              "    pm.response.to.be.json;\r",
              "});\r",
              "\r",
              "// Check Response is not Empty\r",
              "pm.test(\"Response contains data\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.length).to.be.above(0);\r",
              "});\r",
              "\r",
              "// Check Required Fields\r",
              "pm.test(\"First post contains required fields\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "\r",
              "    pm.expect(jsonData[0]).to.have.property(\"userId\");\r",
              "    pm.expect(jsonData[0]).to.have.property(\"id\");\r",
              "    pm.expect(jsonData[0]).to.have.property(\"title\");\r",
              "    pm.expect(jsonData[0]).to.have.property(\"body\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
